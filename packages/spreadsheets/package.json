{
	"name": "peculiar-sheets",
	"version": "0.4.3",
	"description": "A high-performance spreadsheet engine for SolidJS powered by HyperFormula",
	"license": "GPL-3.0-only",
	"author": "peculiarnewbie",
	"repository": {
		"type": "git",
		"url": "https://github.com/peculiarnewbie/spreadsheets"
	},
	"homepage": "https://sheets.peculiarnewbie.com",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./styles": "./dist/sheet.css"
	},
	"files": [
		"dist",
		"LICENSE"
	],
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"prepublishOnly": "tsdown",
		"publish:npm": "tsdown && npm publish --access public"
	},
	"keywords": [
		"spreadsheet",
		"solidjs",
		"sheet",
		"grid",
		"datagrid",
		"formula",
		"hyperformula",
		"excel",
		"cells"
	],
	"peerDependencies": {
		"solid-js": "^1.9.0"
	},
	"dependencies": {
		"@tanstack/solid-virtual": "^3.13.6",
		"better-result": "^2.8.2",
		"hyperformula": "^3.0.0"
	},
	"devDependencies": {
		"@rolldown-plugin/solid": "^0.0.2",
		"tsdown": "^0.12.0",
		"typescript": "^5.8.0"
	}
}
